<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Pdfe.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Pdfe.Avalonia.Controls.PdfViewerControl">

    <Grid>
        <!-- Main PDF display area.
             HorizontalContentAlignment / VerticalContentAlignment center the
             page in the viewport when the scaled content is smaller than the
             ScrollViewer; when the content exceeds the viewport these settings
             have no effect (the scrollbars take over). -->
        <ScrollViewer Name="PdfScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center">

            <!-- LayoutTransformControl participates in layout (RenderTransform
                 doesn't), so when ZoomLevel changes the wrapper's effective
                 size = bitmap size × zoom and the ScrollViewer/scrollbars
                 react correctly. The Image and OverlayCanvas live inside the
                 same wrapper so they always share one transform — no chance
                 of dual-transform drift. -->
            <LayoutTransformControl Name="ZoomHost">
                <LayoutTransformControl.LayoutTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </LayoutTransformControl.LayoutTransform>

                <Grid Name="ContentGrid">
                    <!-- PDF Page Image (no transform here — the wrapper scales us). -->
                    <Image Name="PdfImage" Stretch="None" />

                    <!-- Overlay canvases for annotations. -->
                    <Canvas Name="OverlayCanvas"
                            Background="Transparent"
                            IsHitTestVisible="True">
                        <Canvas Name="AnnotationsLayer" />
                        <Canvas Name="SearchHighlightsLayer" />
                        <Canvas Name="AppliedRedactionsLayer" />
                        <Canvas Name="PendingRedactionsLayer" />
                        <Canvas Name="TextSelectionLayer" />
                        <Canvas Name="HiddenTextRevealLayer" />
                        <Canvas Name="FormFieldsLayer" />
                        <Canvas Name="InteractionLayer" Background="Transparent" />
                        <Canvas Name="TypewriterLayer" />
                    </Canvas>
                </Grid>
            </LayoutTransformControl>
        </ScrollViewer>

        <!-- Continuous (reading) view: a vertically-scrolling, render-virtualized
             stack of all pages. Shown only when ViewMode=Continuous; hidden (and
             not measured) otherwise so the single-page ScrollViewer above owns
             the viewport. No editing overlays here by design — editing always
             happens in single-page mode (#371). -->
        <ScrollViewer Name="ContinuousScrollViewer"
                      IsVisible="False"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalContentAlignment="Center">
            <ItemsControl Name="ContinuousItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="controls:PdfPageSlot">
                        <!-- Border is sized to the (zoomed) page via bindings on
                             the PageSlot VM; the Image stretches the rendered
                             bitmap to fill it. Rendering is kicked on container
                             realization (code-behind) and flows back through the
                             Bitmap binding, so virtualization only renders the
                             pages near the viewport. -->
                        <Border Width="{Binding DisplayWidth}"
                                Height="{Binding DisplayHeight}"
                                Background="White"
                                Margin="0,0,0,12"
                                HorizontalAlignment="Center"
                                BorderBrush="#40000000"
                                BorderThickness="1">
                            <Image Source="{Binding Bitmap}" Stretch="Fill" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Thin indeterminate progress bar pinned to the top edge of the
             viewer. Shown only while a page is rendering. Replaces the
             full-screen "Loading page..." overlay that dominated the
             viewport and made every page change feel jarring; this is the
             standard browser-style "something's happening" affordance. -->
        <ProgressBar Name="LoadingProgressBar"
                     IsVisible="False"
                     IsIndeterminate="True"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Stretch"
                     Height="3"
                     Margin="0"
                     ShowProgressText="False" />

        <!-- Kept for back-compat with code-behind that toggles it. Hidden
             by default; the ProgressBar above is the visible indicator. -->
        <Grid Name="LoadingOverlay"
              IsVisible="False"
              Background="Transparent" />

        <!-- Error overlay. No Background by default → hit-transparent
             outside the centred error message. Code-behind sets a dim
             Background only when an error is actually being shown. -->
        <Grid Name="ErrorOverlay"
              IsVisible="False"
              IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Name="ErrorMessageText"
                           Foreground="Red"
                           FontSize="16"
                           TextWrapping="Wrap"
                           MaxWidth="400" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
