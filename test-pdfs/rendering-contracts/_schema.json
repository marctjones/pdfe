{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pdfe rendering quality contract",
  "type": "object",
  "required": [
    "Path",
    "Pages"
  ],
  "properties": {
    "Path": {
      "type": "string"
    },
    "Source": {
      "type": "string"
    },
    "Password": {
      "type": "string",
      "description": "Known user password required to open this corpus PDF before rendering. Contract-driven scans pass this password to pdfe and every configured reference oracle."
    },
    "Owner": {
      "type": "string"
    },
    "Issue": {
      "type": "integer"
    },
    "RootCause": {
      "type": "string"
    },
    "ReviewStatus": {
      "enum": [
        "REVIEWED",
        "GENERATED",
        "NEEDS_REVIEW"
      ]
    },
    "Target": {
      "type": "object"
    },
    "ImprovementPriority": {
      "enum": [
        "P0",
        "P1",
        "P2",
        "NONE"
      ]
    },
    "Confidence": {
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW"
      ]
    },
    "Pages": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
