      ]
    },
    {
      "id": "image-color:DeviceCMYK",
      "category": "image-color",
      "requiredBy": "Device color space image rendering",
      "detectFeatures": [
        "colorspace:DeviceCMYK"
      ],
      "mustCover": [
        "raw CMYK",
