{
  "schemaVersion": 2,
  "purpose": "Normative coverage matrix for PDF image rendering, stream filters, image dictionaries, and image compositing.",
  "sourceBasis": [
    {
      "id": "iso-32000-1",
      "title": "ISO 32000-1:2008 / PDF 1.7",
      "sections": [
        "7.4 Filters",
        "8.6 Colour spaces",
        "8.9 Images",
        "11 Transparency"
      ],
      "notes": "The public PDF 1.7 standard is the baseline for required stream filters and image XObject behavior."
    },
    {
      "id": "iso-32000-2",
      "title": "ISO 32000-2 / PDF 2.0",
      "sections": [
        "7.4 Filters",
        "8.6 Colour spaces",
        "8.9 Images",
        "11 Transparency"
      ],
      "notes": "PDF 2.0 clarifies and updates behavior, especially around JBIG2 and modern conformance."
    }
  ],
  "coveragePolicy": {
    "requiredLevels": [
      "atomic",
      "corpus"
    ],
    "meaning": {
      "atomic": "A small fixture or unit test constructed to exercise this exact PDF feature obligation.",
      "corpus": "At least one public, real-world, or regression PDF discovered by the inventory and suitable for differential rendering."
    },
    "defaultMinimum": {
      "atomic": 1,
      "corpus": 1
    }
  },
  "corpusSources": [
    {
      "id": "pdfjs",
      "kind": "bug-regression",
      "path": "test-pdfs/pdfjs",
      "downloadScript": "scripts/download-pdfjs-corpus.sh",
      "focus": [
        "historical renderer bugs",
        "JBIG2 fixtures",
        "image masks",
        "color spaces",
        "malformed streams"
      ]
    },
    {
      "id": "poppler",
      "kind": "renderer-regression",
      "path": "test-pdfs/poppler",
      "downloadScript": "scripts/download-poppler-corpus.sh",
      "focus": [
        "filter edge cases",
        "reference images",
        "low-level parser/rendering regressions"
      ]
    },
    {
      "id": "verapdf",
      "kind": "standards-conformance",
      "path": "test-pdfs/verapdf-corpus",
      "downloadScript": "scripts/download-test-pdfs.sh",
      "focus": [
        "PDF/A",
        "PDF/UA",
        "ISO 32000-1",
        "ISO 32000-2 atomic fixtures"
      ]
    },
    {
      "id": "isartor",
      "kind": "standards-conformance",
      "path": "test-pdfs/isartor",
      "downloadScript": "scripts/download-test-pdfs.sh",
      "focus": [
        "PDF/A-1 atomic fixtures"
      ]
    },
    {
      "id": "altona",
      "kind": "print-color",
      "path": "test-pdfs/altona",
      "downloadScript": "scripts/download-standards-image-corpora.sh",
      "focus": [
        "PDF/X",
        "ICC color management",
        "print-oriented image/color quality"
      ]
    },
    {
      "id": "ghent",
      "kind": "print-color",
      "path": "test-pdfs/ghent",
      "downloadScript": "scripts/download-standards-image-corpora.sh",
      "focus": [
        "PDF/X-4",
        "DeviceCMYK",
        "spot color",
        "ICCBased color management",
        "transparency"
      ],
      "manualDownload": true
    }
  ],
  "requirements": [
    {
      "id": "stream-filter:ASCIIHexDecode",
      "category": "stream-filter",
      "requiredBy": "PDF stream filter support",
      "detectFeatures": [
        "filter:ASCIIHexDecode"
      ],
      "mustCover": [
        "full name",
        "abbreviation AHx",
        "odd nibble final byte",
        "whitespace",
        "EOD marker",
        "invalid digit failure"
      ]
    },
    {
      "id": "stream-filter:ASCII85Decode",
      "category": "stream-filter",
      "requiredBy": "PDF stream filter support",
      "detectFeatures": [
        "filter:ASCII85Decode"
      ],
      "mustCover": [
        "full name",
        "abbreviation A85",
        "z short form",
        "partial final tuple",
        "EOD marker",
        "invalid byte failure"
      ]
    },
    {
      "id": "stream-filter:FlateDecode",
      "category": "stream-filter",
      "requiredBy": "PDF stream and raw image support",
      "detectFeatures": [
        "filter:FlateDecode"
      ],
      "mustCover": [
        "full name",
        "abbreviation Fl",
        "zlib stream",
        "raw deflate compatibility",
        "filter arrays",
        "per-filter DecodeParms"
      ]
    },
    {
      "id": "stream-filter:FlateDecode.predictor-tiff",
      "category": "stream-filter-decodeparms",
      "requiredBy": "FlateDecode predictor DecodeParms",
      "detectFeatures": [
        "decodeparms:Predictor:2"
      ],
      "mustCover": [
        "Predictor 2",
        "Colors",
        "Columns",
        "BitsPerComponent"
      ]
    },
    {
      "id": "stream-filter:FlateDecode.predictor-png",
      "category": "stream-filter-decodeparms",
      "requiredBy": "FlateDecode predictor DecodeParms",
      "detectFeatures": [
        "decodeparms:Predictor:10-15"
      ],
      "mustCover": [
        "PNG None",
        "PNG Sub",
        "PNG Up",
        "PNG Average",
        "PNG Paeth",
        "Predictor 10-15 row filter selection"
      ]
    },
    {
      "id": "stream-filter:LZWDecode",
      "category": "stream-filter",
      "requiredBy": "PDF stream and legacy raw image support",
      "detectFeatures": [
        "filter:LZWDecode"
      ],
      "mustCover": [
        "full name",
        "abbreviation LZW",
        "clear code",
        "EOI code",
        "dictionary growth",
        "filter arrays"
      ]
    },
    {
      "id": "stream-filter:LZWDecode.early-change",
      "category": "stream-filter-decodeparms",
      "requiredBy": "LZWDecode DecodeParms",
      "detectFeatures": [
        "decodeparms:EarlyChange"
      ],
      "mustCover": [
        "EarlyChange 0",
        "EarlyChange 1"
      ]
    },
    {
      "id": "stream-filter:LZWDecode.predictors",
      "category": "stream-filter-decodeparms",
      "requiredBy": "LZWDecode predictor DecodeParms",
      "detectFeatures": [
        "filter:LZWDecode",
        "decode:DecodeParms"
      ],
      "mustCover": [
        "TIFF predictor",
        "PNG predictors",
        "Colors",
        "Columns",
        "BitsPerComponent"
      ]
    },
    {
      "id": "stream-filter:RunLengthDecode",
      "category": "stream-filter",
      "requiredBy": "PDF stream and legacy raw image support",
      "detectFeatures": [
        "filter:RunLengthDecode"
      ],
      "mustCover": [
        "full name",
        "abbreviation RL",
        "literal run",
        "repeat run",
        "EOD marker",
        "malformed terminator"
      ]
    },
    {
      "id": "image-filter:CCITTFaxDecode",
      "category": "image-filter",
      "requiredBy": "Bi-level fax image XObject support",
      "detectFeatures": [
        "filter:CCITTFaxDecode"
      ],
      "mustCover": [
        "full name",
        "abbreviation CCF",
        "K 0 one-dimensional Group 3",
        "K positive mixed Group 3",
        "K negative Group 4",
        "Columns",
        "Rows"
      ]
    },
    {
      "id": "image-filter:CCITTFaxDecode.decodeparms",
      "category": "image-filter-decodeparms",
      "requiredBy": "CCITTFaxDecode DecodeParms",
      "detectFeatures": [
        "ccitt:K",
        "decode:DecodeParms"
      ],
      "mustCover": [
        "BlackIs1",
        "EncodedByteAlign",
        "EndOfLine",
        "EndOfBlock",
        "DamagedRowsBeforeError"
      ]
    },
    {
      "id": "image-filter:DCTDecode",
      "category": "image-filter",
      "requiredBy": "JPEG image XObject support",
      "detectFeatures": [
        "filter:DCTDecode"
      ],
      "mustCover": [
        "full name",
        "abbreviation DCT",
        "baseline JPEG",
        "progressive JPEG",
        "grayscale",
        "RGB",
        "CMYK",
        "YCCK",
        "filter arrays"
      ]
    },
    {
      "id": "image-filter:DCTDecode.color-transform",
      "category": "image-filter-decodeparms",
      "requiredBy": "JPEG color interpretation in PDF",
      "detectFeatures": [
        "dct:ColorTransform"
      ],
      "mustCover": [
        "DecodeParms ColorTransform 0",
        "DecodeParms ColorTransform 1",
        "Adobe APP14 transform 0",
        "Adobe APP14 transform 1",
        "Adobe APP14 transform 2",
        "APP14 override precedence"
      ]
    },
    {
      "id": "image-filter:JPXDecode",
      "category": "image-filter",
      "requiredBy": "JPEG 2000 / JPX image XObject support",
      "detectFeatures": [
        "filter:JPXDecode"
      ],
      "mustCover": [
        "codestream",
        "JP2 wrapper",
        "gray",
        "RGB",
        "CMYK",
        "indexed",
        "embedded alpha",
        "component definitions",
        "16-bit components"
      ]
    },
    {
      "id": "image-filter:JBIG2Decode",
      "category": "image-filter",
      "requiredBy": "JBIG2 bi-level image XObject support",
      "detectFeatures": [
        "filter:JBIG2Decode"
      ],
      "mustCover": [
        "generic region",
        "symbol dictionary",
        "text region",
        "refinement region",
        "pattern dictionary",
        "halftone region",
        "MMR",
        "arithmetic",
        "sequential organization",
        "random-access organization"
      ]
    },
    {
      "id": "image-filter:JBIG2Decode.globals",
      "category": "image-filter-decodeparms",
      "requiredBy": "JBIG2Decode DecodeParms",
      "detectFeatures": [
        "jbig2:Globals"
      ],
      "mustCover": [
        "JBIG2Globals stream",
        "shared symbol dictionaries",
        "multi-image reuse"
      ]
    },
    {
      "id": "stream-filter:Crypt",
      "category": "stream-filter",
      "requiredBy": "Encrypted stream filter handling",
      "detectFeatures": [
        "filter:Crypt"
      ],
      "mustCover": [
        "Identity crypt filter",
        "named crypt filter",
        "filter order with compression filters"
      ],
      "minimumCoverage": {
        "atomic": 1,
        "corpus": 0
      }
    },
    {
      "id": "stream-filter-arrays",
      "category": "stream-filter-composition",
      "requiredBy": "PDF stream filter arrays",
      "detectFeatures": [
        "filter:array"
      ],
      "mustCover": [
        "multiple filters",
        "per-filter DecodeParms array",
        "null DecodeParms entries",
        "abbreviated names inside arrays"
      ]
    },
    {
      "id": "image-dictionary:ImageMask",
      "category": "image-mask",
      "requiredBy": "Stencil image rendering",
      "detectFeatures": [
        "image:ImageMask"
      ],
      "mustCover": [
        "default Decode",
        "Decode [1 0]",
        "current fill color",
        "alpha interaction",
        "CTM transforms"
      ]
    },
    {
      "id": "image-dictionary:SMask",
      "category": "image-mask",
      "requiredBy": "Soft-mask image compositing",
      "detectFeatures": [
        "image:SMask"
      ],
      "mustCover": [
        "gray image soft mask",
        "image soft mask",
        "mask Decode",
        "transparency group interaction"
      ]
    },
    {
      "id": "image-dictionary:Mask.image",
      "category": "image-mask",
      "requiredBy": "Explicit image mask compositing",
      "detectFeatures": [
        "image:Mask"
      ],
      "mustCover": [
        "explicit image mask",
        "indexed base image",
        "DCT base image"
      ]
    },
    {
      "id": "image-dictionary:Mask.color-key",
      "category": "image-mask",
      "requiredBy": "Color-key mask compositing",
      "detectFeatures": [
        "image:ColorKeyMask"
      ],
      "mustCover": [
        "DeviceGray ranges",
        "DeviceRGB ranges",
        "DeviceCMYK ranges",
        "Indexed ranges"
      ]
    },
    {
      "id": "image-dictionary:Decode",
      "category": "image-decode",
      "requiredBy": "PDF image sample remapping",
      "detectFeatures": [
        "decode:ExplicitDecode"
      ],
      "mustCover": [
        "inverted grayscale",
        "inverted CMYK",
        "Lab ranges",
        "indexed passthrough",
        "image masks"
      ]
    },
    {
      "id": "image-dictionary:BitsPerComponent",
      "category": "image-samples",
      "requiredBy": "Image sample unpacking",
      "detectFeatures": [
        "bpc:1",
        "bpc:2",
        "bpc:4",
        "bpc:8",
        "bpc:16"
      ],
      "mustCover": [
        "1-bit",
        "2-bit",
        "4-bit",
        "8-bit",
        "16-bit"
      ]
    },
    {
      "id": "image-dictionary:Interpolate",
      "category": "image-sampling",
      "requiredBy": "Image interpolation hint handling",
      "detectFeatures": [
        "image:Interpolate"
      ],
      "mustCover": [
        "Interpolate false",
        "Interpolate true",
        "large upsample",
        "downsample"
      ]
    },
    {
