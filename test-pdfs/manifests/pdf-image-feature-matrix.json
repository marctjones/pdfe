        "JPX/Flate image data"
      ]
    },
    {
      "id": "image-color:Separation",
      "category": "image-color",
      "requiredBy": "Spot-color image handling",
      "detectFeatures": [
        "colorspace:Separation"
      ],
      "mustCover": [
        "alternate tint transform",
        "image data",
        "soft masks",
        "overprint interactions"
      ]
    },
    {
      "id": "image-color:DeviceN",
      "category": "image-color",
      "requiredBy": "Multi-ink image handling",
      "detectFeatures": [
        "colorspace:DeviceN"
      ],
      "mustCover": [
