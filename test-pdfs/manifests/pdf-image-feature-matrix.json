    {
      "id": "resource-policy:image-limits",
      "category": "resource-policy",
      "requiredBy": "Bounded rendering of malformed or adversarial image streams",
      "detectFeatures": [
        "policy:ResourceLimit"
      ],
      "mustCover": [
        "huge dimensions",
        "large decoded byte count",
        "expansion bombs",
        "JBIG2 complexity",
        "timeouts",
        "recoverable malformed content"
