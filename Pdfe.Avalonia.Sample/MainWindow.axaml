<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pdf="using:Pdfe.Avalonia.Controls"
        x:Class="Pdfe.Avalonia.Sample.MainWindow"
        Width="900" Height="1000"
        Title="Pdfe.Avalonia sample">
    <DockPanel>
        <!-- Toolbar: drives the control through its public API. -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="8">
            <Button Name="OpenButton" Content="Open PDF…" Click="OnOpen" />
            <Button Content="◀ Prev" Click="OnPrev" />
            <Button Content="Next ▶" Click="OnNext" />
            <Button Content="–" Click="OnZoomOut" />
            <Button Content="+" Click="OnZoomIn" />
            <Button Content="Actual size" Click="OnActualSize" />
            <TextBlock Name="PageLabel" VerticalAlignment="Center" Margin="8,0" />
        </StackPanel>

        <!-- The reusable viewer control. -->
        <pdf:PdfViewerControl Name="Viewer" PageChanged="OnPageChanged" />
    </DockPanel>
</Window>
