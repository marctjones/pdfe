<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Excise.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="Excise.App.Views.PreferencesWindow"
        x:DataType="vm:PreferencesViewModel"
        Title="Preferences"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Design.DataContext>
        <vm:PreferencesViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,15">
            <TextBlock Text="Preferences"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="20">

                <!-- Rendering Settings Section -->
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Rendering &amp; Performance"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Text="Configure PDF rendering and caching"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <Separator/>

                        <!-- Render Cache -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Render Cache Size" FontWeight="Medium"/>
                            <NumericUpDown Value="{Binding RenderCacheMax}"
                                           Minimum="1" Maximum="200"
                                           Increment="5"
                                           FormatString="0"
                                           AutomationProperties.Name="Render Cache Size"
                                           AutomationProperties.HelpText="Maximum number of rendered pages to keep in memory."/>
                            <TextBlock Text="Maximum number of pages to keep in memory (higher = faster navigation, more RAM)"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,15">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">
                <Button Content="Reset to Defaults"
                        Command="{Binding ResetToDefaultsCommand}"
                        Classes="modern-button"
                        AutomationProperties.Name="Reset Preferences to Defaults"
                        AutomationProperties.HelpText="Restore preference values to their defaults."
                        Padding="15,8"/>
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Classes="modern-button"
                        IsCancel="True"
                        AutomationProperties.Name="Cancel Preferences"
                        AutomationProperties.HelpText="Close preferences without saving changes."
                        Padding="15,8"/>
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Classes="modern-button accent"
                        IsDefault="True"
                        AutomationProperties.Name="Save Preferences"
                        AutomationProperties.HelpText="Save preference changes and close this dialog."
                        Padding="15,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
