<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PdfEditor.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="560"
        x:Class="PdfEditor.Views.AboutWindow"
        x:DataType="vm:AboutWindowViewModel"
        Title="About pdfe"
        Width="780" Height="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        CanResize="True">

    <Window.DataContext>
        <vm:AboutWindowViewModel/>
    </Window.DataContext>

    <DockPanel Margin="16">

        <!-- Header: logo + name + version + tagline -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12"
              ColumnDefinitions="Auto,*">
            <Image Grid.Column="0"
                   Width="64" Height="64"
                   Source="/Assets/pdfe_logo_64.png"
                   VerticalAlignment="Top"
                   Margin="0,0,16,0"/>
            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="{Binding AppName}"
                           FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding AppVersion, StringFormat='version {0}'}"
                           Opacity="0.7"/>
                <TextBlock Text="{Binding Tagline}"
                           TextWrapping="Wrap" Margin="0,6,0,0"/>
                <TextBlock Text="{Binding Copyright}"
                           FontSize="11" Opacity="0.7" Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,6,0,0">
                    <Button Content="Visit GitHub"
                            Click="OnVisitGitHubClicked"
                            AutomationProperties.Name="Visit GitHub"
                            AutomationProperties.HelpText="Open the pdfe GitHub project page in a browser."/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Separator DockPanel.Dock="Top" Margin="0,0,0,8"/>

        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,4" FontWeight="SemiBold">
            Third-party libraries
        </TextBlock>
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8"
                   Text="{Binding Packages.Count, StringFormat='{}{0} packages — full notices below'}"
                   Opacity="0.7" FontSize="11"/>

        <!-- Footer button row pinned to the bottom -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Click="OnCloseClicked"
                    Padding="20,6" IsDefault="True" IsCancel="True"
                    AutomationProperties.Name="Close About Dialog"
                    AutomationProperties.HelpText="Close the about dialog."/>
        </StackPanel>

        <!-- Master/detail: package list on the left, full text on the right. -->
        <Grid ColumnDefinitions="280,*">
            <ListBox Grid.Column="0"
                     Name="PackagesList"
                     ItemsSource="{Binding Packages}"
                     SelectionMode="Single"
                     AutomationProperties.Name="Third-party Libraries"
                     AutomationProperties.HelpText="Select a package to view its license notice."
                     SelectionChanged="OnSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ThirdPartyPackage">
                        <StackPanel Spacing="0" Margin="2">
                            <TextBlock Text="{Binding Id}" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Version}"
                                           FontSize="11" Opacity="0.7"/>
                                <TextBlock Text="·" FontSize="11" Opacity="0.5"/>
                                <TextBlock Text="{Binding LicenseName}"
                                           FontSize="11" Opacity="0.85"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Detail pane -->
            <Border Grid.Column="1" Margin="12,0,0,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="10">
                <ScrollViewer>
                    <StackPanel Name="DetailPanel" Spacing="6">
                        <TextBlock Text="Select a package to view its license."
                                   Opacity="0.6" FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
