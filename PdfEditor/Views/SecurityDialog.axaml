<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PdfEditor.ViewModels"
        x:Class="PdfEditor.Views.SecurityDialog"
        x:DataType="vm:SecurityDialogViewModel"
        Title="Document Security"
        Width="480"
        Height="440"
        WindowStartupLocation="CenterOwner"
        CanResize="false"
        Background="#2b2b2b"
        Foreground="#f0f0f0">

    <Border Padding="20">
        <StackPanel Spacing="12">

            <!-- Header -->
            <TextBlock Text="Document Security"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#f0f0f0"/>
            <TextBlock Text="Set, change, or remove password protection. Saving writes a new file — the currently open document is not modified in place."
                       TextWrapping="Wrap"
                       Foreground="#a0a0a0"
                       FontSize="12"/>

            <Separator Background="#444" />

            <!-- Current password (only relevant on an already-encrypted document) -->
            <StackPanel Spacing="4" IsVisible="{Binding IsEncrypted}" IsEnabled="{Binding CanEditOptions}">
                <TextBlock Text="Current password:" FontWeight="Medium" Foreground="#d0d0d0"/>
                <TextBox Text="{Binding CurrentPassword}"
                         PasswordChar="•"
                         PlaceholderText="Required to change or remove protection"
                         AutomationProperties.Name="Current Password"
                         AutomationProperties.HelpText="The password that currently protects this document. Required before applying any change."/>
            </StackPanel>

            <!-- New passwords -->
            <StackPanel Spacing="8" IsEnabled="{Binding CanEditOptions}">
                <StackPanel Spacing="4">
                    <TextBlock Text="New user password (required to open):" FontWeight="Medium" Foreground="#d0d0d0"/>
                    <TextBox Text="{Binding NewUserPassword}"
                             PasswordChar="•"
                             PlaceholderText="Leave blank for no open password"
                             AutomationProperties.Name="New User Password"
                             AutomationProperties.HelpText="Password required to open the document. Leave blank for none."/>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="New owner password (permissions):" FontWeight="Medium" Foreground="#d0d0d0"/>
                    <TextBox Text="{Binding NewOwnerPassword}"
                             PasswordChar="•"
                             PlaceholderText="Leave blank for no owner password"
                             AutomationProperties.Name="New Owner Password"
                             AutomationProperties.HelpText="Password required to change permissions. Leave blank for none."/>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="Algorithm:" FontWeight="Medium" Foreground="#d0d0d0"/>
                    <ComboBox ItemsSource="{Binding Algorithms}"
                              SelectedItem="{Binding Algorithm}"
                              AutomationProperties.Name="Encryption Algorithm"
                              AutomationProperties.HelpText="AES-256 (PDF 2.0, default) or AES-128 for older readers."
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
            </StackPanel>

            <!-- Result -->
            <TextBlock Text="{Binding ResultMessage}"
                       TextWrapping="Wrap"
                       Foreground="#4ec9b0"
                       FontSize="12"
                       IsVisible="{Binding ResultMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap"
                       Foreground="#f0b0b0"
                       FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,10,0,0">
                <Button Grid.Column="1"
                        Content="{Binding CloseButtonText}"
                        Command="{Binding CloseCommand}"
                        Width="90"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        AutomationProperties.Name="Close Security Dialog"
                        AutomationProperties.HelpText="Close this dialog without further changes."/>

                <Button Grid.Column="2"
                        Content="Remove Protection"
                        Command="{Binding RemoveProtectionCommand}"
                        IsEnabled="{Binding CanRemove}"
                        IsVisible="{Binding IsEncrypted}"
                        Width="140"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Remove Password Protection"
                        AutomationProperties.HelpText="Explicitly save an unprotected copy of the document. This is the only action that drops encryption; leaving the password fields blank and clicking Apply does not."/>

                <Button Grid.Column="3"
                        Content="Apply"
                        Command="{Binding ApplyCommand}"
                        IsEnabled="{Binding CanApply}"
                        Width="90"
                        Classes="primary"
                        IsDefault="True"
                        AutomationProperties.Name="Apply Security Settings"
                        AutomationProperties.HelpText="Save a copy of the document with the password/algorithm settings above."/>
            </Grid>

        </StackPanel>
    </Border>

</Window>
