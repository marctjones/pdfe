<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PdfEditor.ViewModels"
        xmlns:models="using:PdfEditor.Models"
        xmlns:controls="using:PdfEditor.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="PdfEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="MainWin"
        Title="PDF Editor"
        Icon="/Assets/pdfe_logo_256.png"
        Width="1200" Height="800"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40"
        Background="{DynamicResource AppBackgroundBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}">
            <!-- FILE MENU -->
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Command="{Binding OpenFileCommand}" InputGesture="Ctrl+O">
                    <MenuItem.Icon><TextBlock Text="📁"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding SaveButtonText, StringFormat='_{0}'}" Command="{Binding SaveFileCommand}" InputGesture="Ctrl+S">
                    <MenuItem.Icon><TextBlock Text="💾"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGesture="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Recent Files" Name="RecentFilesMenu" ItemsSource="{Binding RecentFileMenuItems}">
                    <!-- Placeholder shown when menu has no items (ensures submenu arrow appears) -->
                    <MenuItem.Styles>
                        <Style Selector="MenuItem:empty">
                            <Setter Property="IsVisible" Value="True"/>
                        </Style>
                    </MenuItem.Styles>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Close Document" Command="{Binding CloseDocumentCommand}" InputGesture="Ctrl+W"/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" InputGesture="Alt+F4"/>
            </MenuItem>

            <!-- EDIT MENU -->
            <MenuItem Header="_Edit">
                <MenuItem Header="_Find..." Command="{Binding ToggleSearchCommand}" InputGesture="Ctrl+F">
                    <MenuItem.Icon><TextBlock Text="🔍"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Find _Next" Command="{Binding FindNextCommand}" InputGesture="F3"/>
                <MenuItem Header="Find _Previous" Command="{Binding FindPreviousCommand}" InputGesture="Shift+F3"/>
                <Separator/>
                <MenuItem Header="_Select Text Mode" Command="{Binding ToggleTextSelectionModeCommand}" InputGesture="T">
                    <MenuItem.Icon>
                        <TextBlock Text="✓" IsVisible="{Binding IsTextSelectionMode}"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Copy Selected Text" Command="{Binding CopyTextCommand}" InputGesture="Ctrl+C"
                          IsEnabled="{Binding IsTextSelectionMode}"/>
            </MenuItem>

            <!-- DOCUMENT MENU -->
            <MenuItem Header="_Document">
                <MenuItem Header="_Add Pages..." Command="{Binding AddPagesCommand}">
                    <MenuItem.Icon><TextBlock Text="➕"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Remove Current Page" Command="{Binding RemoveCurrentPageCommand}"
                          IsEnabled="{Binding IsDocumentLoaded}">
                    <MenuItem.Icon><TextBlock Text="🗑"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Rotate _Left 90°" Command="{Binding RotatePageLeftCommand}" InputGesture="Ctrl+L"/>
                <MenuItem Header="Rotate _Right 90°" Command="{Binding RotatePageRightCommand}" InputGesture="Ctrl+R"/>
                <MenuItem Header="Rotate _180°" Command="{Binding RotatePage180Command}"/>
                <Separator/>
                <MenuItem Header="_Export Current Page..." Command="{Binding ExportCurrentPageCommand}" InputGesture="Ctrl+E"/>
                <MenuItem Header="Export _All Pages as Images..." Command="{Binding ExportPagesCommand}"/>
                <MenuItem Header="_Print..." Command="{Binding PrintCommand}" InputGesture="Ctrl+P"/>
            </MenuItem>

            <!-- REDACTION MENU -->
            <MenuItem Header="_Redaction">
                <MenuItem Header="_Enable Redaction Mode" Command="{Binding ToggleRedactionModeCommand}" InputGesture="R">
                    <MenuItem.Icon>
                        <TextBlock Text="✓" IsVisible="{Binding IsRedactionMode}"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Apply Redaction" Command="{Binding ApplyRedactionCommand}" InputGesture="Enter"
                          IsEnabled="{Binding IsRedactionMode}">
                    <MenuItem.Icon><TextBlock Text="⬛" Foreground="Red"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_View Clipboard History"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsClipboardSidebarVisible, Mode=TwoWay}">
                    <MenuItem.Icon><TextBlock Text="📋"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- TOOLS MENU -->
            <MenuItem Header="_Tools">
                <MenuItem Header="_Verify Digital Signatures..." Command="{Binding VerifySignaturesCommand}"
                          IsEnabled="{Binding IsDocumentLoaded}">
                    <MenuItem.Icon><TextBlock Text="🔐"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Reveal _Hidden Text (audit overlay)"
                          ToolTip.Tip="Surface text that is present in the PDF but visually covered by an opaque overlay — the classic 'black-box redaction' failure mode."
                          IsEnabled="{Binding IsDocumentLoaded}"
                          ToggleType="CheckBox"
                          IsChecked="{Binding RevealHiddenText, Mode=TwoWay}" />
                <MenuItem Header="Reveal _Rasterized Hidden Text (deep / OCR)"
                          ToolTip.Tip="Also run differential OCR: render the page with overlays stripped, OCR both versions, and surface words present only in the underlying raster. Slower; requires 'tesseract' on PATH."
                          IsEnabled="{Binding IsDocumentLoaded}"
                          ToggleType="CheckBox"
                          IsChecked="{Binding RevealRasterizedHidden, Mode=TwoWay}" />
                <Separator/>
                <MenuItem Header="_Preferences..." Command="{Binding ShowPreferencesCommand}" InputGesture="Ctrl+,">
                    <MenuItem.Icon><TextBlock Text="⚙"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- VIEW MENU -->
            <MenuItem Header="_View">
                <MenuItem Header="_Zoom In" Command="{Binding ZoomInCommand}" InputGesture="Ctrl++"/>
                <MenuItem Header="Zoom _Out" Command="{Binding ZoomOutCommand}" InputGesture="Ctrl+-"/>
                <MenuItem Header="_Actual Size" Command="{Binding ZoomActualSizeCommand}" InputGesture="Ctrl+0"/>
                <Separator/>
                <MenuItem Header="Fit _Width" Command="{Binding ZoomFitWidthCommand}" InputGesture="Ctrl+1"/>
                <MenuItem Header="Fit _Page" Command="{Binding ZoomFitPageCommand}" InputGesture="Ctrl+2"/>
                <Separator/>
                <MenuItem Header="Show _Outline"
                          ToggleType="CheckBox"
                          InputGesture="Ctrl+Shift+O"
                          IsChecked="{Binding IsOutlineSidebarVisible, Mode=TwoWay}"/>
                <MenuItem Header="Show _Thumbnails"
                          ToggleType="CheckBox"
                          InputGesture="Ctrl+Shift+T"
                          IsChecked="{Binding IsThumbnailsSidebarVisible, Mode=TwoWay}"/>
                <MenuItem Header="Show _Clipboard History"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsClipboardSidebarVisible, Mode=TwoWay}"/>
            </MenuItem>

            <!-- HELP MENU -->
            <MenuItem Header="_Help">
                <MenuItem Header="_Keyboard Shortcuts" Command="{Binding ShowShortcutsCommand}" InputGesture="F1"/>
                <MenuItem Header="_Documentation" Command="{Binding ShowDocumentationCommand}"/>
                <Separator/>
                <MenuItem Header="_About PDF Editor" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toast Notification InfoBar -->
        <ui:FAInfoBar x:Name="ToastInfoBar" Grid.Row="1" IsOpen="False" IsClosable="True" Margin="0"/>

        <!-- Modern Title Bar Area -->
        <Grid Grid.Row="2" Height="40" Background="{DynamicResource ToolbarBackgroundBrush}"
              ColumnDefinitions="Auto,*,Auto">
            <!-- App Icon and Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" Margin="10,0">
                <TextBlock Text="PDF Editor"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Center area for document name -->
            <TextBlock Grid.Column="1"
                       Text="{Binding DocumentName, FallbackValue='No document open'}"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Grid>

        <!-- Simplified Toolbar with Grouped Actions -->
        <Border Grid.Row="3"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Left: Main Actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                    <!-- View Group: sidebar toggles (outline + page previews) -->
                    <Button Content="📑" Command="{Binding ToggleOutlineCommand}"
                            Classes="modern-button toggle"
                            Classes.active="{Binding IsOutlineSidebarVisible}"
                            Padding="10,6"
                            ToolTip.Tip="Show/hide Outline (Ctrl+Shift+O)"
                            AutomationProperties.Name="Toggle Outline Sidebar"
                            AutomationProperties.HelpText="Show or hide the document outline / bookmarks panel"/>
                    <Button Content="🗐" Command="{Binding ToggleThumbnailsCommand}"
                            Classes="modern-button toggle"
                            Classes.active="{Binding IsThumbnailsSidebarVisible}"
                            Padding="10,6"
                            ToolTip.Tip="Show/hide Page Previews (Ctrl+Shift+T)"
                            AutomationProperties.Name="Toggle Thumbnails Sidebar"
                            AutomationProperties.HelpText="Show or hide the page thumbnails / previews panel"/>

                    <Border Width="1" Height="24" Margin="6,0"
                            Background="{DynamicResource DividerBrush}"/>

                    <!-- File Group -->
                    <Button Content="📁 Open" Command="{Binding OpenFileCommand}"
                            Classes="modern-button" Padding="12,6"
                            ToolTip.Tip="Open PDF (Ctrl+O)"
                            AutomationProperties.Name="Open PDF File"
                            AutomationProperties.HelpText="Opens a file dialog to select a PDF document"/>
                    <Button Content="{Binding SaveButtonText, StringFormat='💾 {0}'}" Command="{Binding SaveFileCommand}"
                            Classes="modern-button" Padding="12,6"
                            ToolTip.Tip="Save (Ctrl+S)"
                            AutomationProperties.Name="Save Document"
                            AutomationProperties.HelpText="Saves the current PDF document"/>

                    <Border Width="1" Height="24" Margin="6,0"
                            Background="{DynamicResource DividerBrush}"/>

                    <!-- Mode Toggles -->
                    <Button Content="📝 Select Text" Command="{Binding ToggleTextSelectionModeCommand}"
                            Classes="modern-button toggle"
                            Classes.active="{Binding IsTextSelectionMode}"
                            Padding="12,6"
                            ToolTip.Tip="Text Selection Mode (T)"
                            AutomationProperties.Name="Text Selection Mode"
                            AutomationProperties.HelpText="Toggle text selection mode to select and copy text"/>

                    <Button Content="⬛ Redact" Command="{Binding ToggleRedactionModeCommand}"
                            Classes="modern-button toggle"
                            Classes.active="{Binding IsRedactionMode}"
                            Padding="12,6"
                            ToolTip.Tip="Redaction Mode (R)"
                            AutomationProperties.Name="Redaction Mode"
                            AutomationProperties.HelpText="Toggle redaction mode to mark areas for removal"/>

                    <Button Content="✓ Apply" Command="{Binding ApplyRedactionCommand}"
                            Classes="modern-button primary"
                            Padding="12,6"
                            IsEnabled="{Binding IsRedactionMode}"
                            IsVisible="{Binding IsRedactionMode}"
                            ToolTip.Tip="Apply Redaction (Enter)"
                            AutomationProperties.Name="Apply Redaction"
                            AutomationProperties.HelpText="Apply the current redaction selection"/>

                    <Border Width="1" Height="24" Margin="6,0"
                            Background="{DynamicResource DividerBrush}"/>

                    <!-- Form Authoring -->
                    <Button Content="📋 Add Field" Command="{Binding ToggleFormAuthoringModeCommand}"
                            Classes="modern-button toggle"
                            Classes.active="{Binding IsFormAuthoringMode}"
                            Padding="12,6"
                            ToolTip.Tip="Form Authoring Mode — drag to define a new field"
                            AutomationProperties.Name="Form Authoring Mode"/>

                    <ComboBox SelectedIndex="0"
                              IsVisible="{Binding IsFormAuthoringMode}"
                              SelectionChanged="OnFormFieldTypeChanged"
                              ToolTip.Tip="Field type for the next drag"
                              MinWidth="100" Margin="4,0">
                        <ComboBoxItem Content="Text"/>
                        <ComboBoxItem Content="Checkbox"/>
                        <ComboBoxItem Content="Choice"/>
                        <ComboBoxItem Content="Signature"/>
                    </ComboBox>

                    <Button Content="🪄 Auto-detect" Command="{Binding AutoDetectFieldsCommand}"
                            Classes="modern-button"
                            Padding="12,6"
                            ToolTip.Tip="Heuristically add form fields where the page has underline placeholders or empty squares"
                            AutomationProperties.Name="Auto-detect Form Fields"/>

                    <Border Width="1" Height="24" Margin="6,0"
                            Background="{DynamicResource DividerBrush}"/>

                    <!-- Tools Group -->
                    <Button Content="🔍 Find" Command="{Binding ToggleSearchCommand}"
                            Classes="modern-button" Padding="12,6"
                            ToolTip.Tip="Find Text (Ctrl+F)"
                            AutomationProperties.Name="Find Text"
                            AutomationProperties.HelpText="Opens the search bar to find text in the document"/>



                    <Border Width="1" Height="24" Margin="6,0"
                            Background="{DynamicResource DividerBrush}"/>

                    <!-- Page Rotation -->
                    <Button Content="↺" Command="{Binding RotatePageLeftCommand}"
                            Classes="modern-button" Padding="10,6" FontSize="16"
                            ToolTip.Tip="Rotate Left (Ctrl+L)"
                            AutomationProperties.Name="Rotate Page Left"
                            AutomationProperties.HelpText="Rotate the current page 90 degrees counter-clockwise"/>
                    <Button Content="↻" Command="{Binding RotatePageRightCommand}"
                            Classes="modern-button" Padding="10,6" FontSize="16"
                            ToolTip.Tip="Rotate Right (Ctrl+R)"
                            AutomationProperties.Name="Rotate Page Right"
                            AutomationProperties.HelpText="Rotate the current page 90 degrees clockwise"/>
                </StackPanel>

                <!-- Right: Zoom Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Content="−" Command="{Binding ZoomOutCommand}"
                            Classes="modern-button" Padding="10,6" FontWeight="Bold"
                            ToolTip.Tip="Zoom Out (Ctrl+-)"
                            AutomationProperties.Name="Zoom Out"
                            AutomationProperties.HelpText="Decrease zoom level"/>
                    <TextBlock Text="{Binding ZoomLevel, StringFormat='{}{0:P0}'}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               MinWidth="45" TextAlignment="Center"
                               FontSize="12" FontWeight="Medium"
                               AutomationProperties.Name="Zoom Level"/>
                    <Button Content="+" Command="{Binding ZoomInCommand}"
                            Classes="modern-button" Padding="10,6" FontWeight="Bold"
                            ToolTip.Tip="Zoom In (Ctrl++)"
                            AutomationProperties.Name="Zoom In"
                            AutomationProperties.HelpText="Increase zoom level"/>
                    <Button Content="Fit" Command="{Binding ZoomFitWidthCommand}"
                            Classes="modern-button" Padding="10,6" FontSize="11"
                            ToolTip.Tip="Fit Width (Ctrl+1)"
                            AutomationProperties.Name="Fit to Width"
                            AutomationProperties.HelpText="Fit page to window width"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="4"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6"
                IsVisible="{Binding IsSearchVisible}">
          <StackPanel Orientation="Vertical" Spacing="4">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <!-- Search Label -->
                <TextBlock Grid.Column="0" Text="Find:"
                           VerticalAlignment="Center"
                           Margin="4,0,8,0"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <!-- Search TextBox. KeyDown is wired in code-behind so
                     Enter triggers search immediately (in addition to
                     the type-and-pause debounce). -->
                <TextBox x:Name="SearchTextBox"
                         Grid.Column="1"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search text… (auto-searches as you type, or press Enter)"
                         MinWidth="300"
                         Margin="0,0,8,0"
                         KeyDown="OnSearchTextBoxKeyDown"
                         AutomationProperties.Name="Search Text"
                         AutomationProperties.HelpText="Enter text to search for in the document"/>

                <!-- Find button — manual fallback if auto-search isn't
                     obvious to the user. -->
                <Button Grid.Column="2"
                        Content="Find"
                        Command="{Binding FindCommand}"
                        Classes="modern-button compact"
                        Padding="12,4"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Find"
                        AutomationProperties.HelpText="Search the document for the entered text"/>

                <!-- Case Sensitive Checkbox -->
                <CheckBox Grid.Column="3"
                          IsChecked="{Binding SearchCaseSensitive}"
                          Content="Case sensitive"
                          Margin="0,0,8,0"/>

                <!-- Whole Words Checkbox -->
                <CheckBox Grid.Column="4"
                          IsChecked="{Binding SearchWholeWords}"
                          Content="Whole words"
                          Margin="0,0,8,0"/>

                <!-- Regex Checkbox -->
                <CheckBox Grid.Column="5"
                          IsChecked="{Binding SearchUseRegex}"
                          Content="Regex"
                          Margin="0,0,8,0"
                          ToolTip.Tip="Use regular expression pattern matching"/>

                <!-- Previous Button -->
                <Button Grid.Column="6"
                        Content="◀"
                        Command="{Binding FindPreviousCommand}"
                        Classes="modern-button compact"
                        Padding="8,4"
                        Margin="0,0,4,0"
                        AutomationProperties.Name="Find Previous"
                        AutomationProperties.HelpText="Navigate to previous search result"/>

                <!-- Next Button -->
                <Button Grid.Column="7"
                        Content="▶"
                        Command="{Binding FindNextCommand}"
                        Classes="modern-button compact"
                        Padding="8,4"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Find Next"
                        AutomationProperties.HelpText="Navigate to next search result"/>

                <!-- Result Counter -->
                <TextBlock Grid.Column="8"
                           Text="{Binding SearchResultText}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,8,0"
                           MinWidth="80"/>

                <!-- Close Button -->
                <Button Grid.Column="9"
                        Content="✕"
                        Command="{Binding CloseSearchCommand}"
                        Classes="modern-button compact"
                        Padding="8,4"
                        AutomationProperties.Name="Close Search"
                        AutomationProperties.HelpText="Close the find bar"/>
            </Grid>

            <!-- Inline search progress: indeterminate bar + page-progress
                 text. Both visible only while a search is actively running.
                 The "X of Y matches" final-state count stays in
                 SearchResultText so this row vanishes when the search
                 completes. -->
            <Grid ColumnDefinitions="*,Auto"
                  IsVisible="{Binding IsSearching}"
                  Margin="0,2,0,0">
                <ProgressBar Grid.Column="0"
                             IsIndeterminate="True"
                             Height="2"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             ShowProgressText="False" />
                <TextBlock Grid.Column="1"
                           Text="{Binding SearchProgressText}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Main Content Area. Auto/Auto on the sidebar columns lets them
             collapse to 0 width when their Border's IsVisible flips false,
             so toggling Show Thumbnails / Show Clipboard History gives the
             central pane the freed space rather than just blanking the
             column. -->
        <Grid Grid.Row="5" ColumnDefinitions="Auto,*,Auto">

            <!-- Thumbnail Sidebar — split into Outline (top) + Thumbnails (bottom).
                 The outline pane only takes screen space when the document
                 actually has a table of contents (HasOutline) AND the user
                 hasn't toggled it off via View → Show Outline. -->
            <Border Grid.Column="0"
                    Width="220"
                    IsVisible="{Binding IsLeftSidebarVisible}"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
              <Grid RowDefinitions="*,Auto,*">

                <!-- Outline / Table of Contents -->
                <Grid Grid.Row="0" RowDefinitions="Auto,*"
                      IsVisible="{Binding IsOutlineSidebarVisible}">
                    <Border Grid.Row="0"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <TextBlock Text="Outline"
                                   FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                    <!-- Bind SelectedItem to VM. The setter on
                         SelectedOutlineNode jumps the viewer; this is the
                         simplest cross-platform pattern that works inside
                         TreeView's container chain (a per-row Button.Command
                         binding does NOT reliably resolve $parent[Window]
                         through the templated ItemContainer hierarchy). -->
                    <!-- PointerPressed at the TreeView level + a manual
                         walk to the clicked TreeViewItem. The SelectedItem
                         TwoWay binding works in tests under FluentTheme but
                         FluentAvalonia's TreeViewItem theme can swallow
                         clicks on the chevron/content boundary, so the
                         straightforward selection path silently no-ops in
                         the real app. The pointer handler is theme-
                         independent. -->
                    <ScrollViewer Grid.Row="1">
                        <TreeView Name="OutlineTree"
                                  ItemsSource="{Binding OutlineNodes}"
                                  SelectedItem="{Binding SelectedOutlineNode, Mode=TwoWay}"
                                  PointerPressed="OnOutlineTreePointerPressed"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Cursor="Hand"/>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </Grid>

                <!-- Splitter between outline and thumbnails (only when both visible). -->
                <GridSplitter Grid.Row="1"
                              Height="2"
                              Background="{DynamicResource BorderBrush}"
                              HorizontalAlignment="Stretch"
                              ResizeDirection="Rows"
                              IsVisible="{Binding IsSidebarSplitterVisible}"/>

                <!-- Thumbnails -->
                <Grid Grid.Row="2" RowDefinitions="Auto,*"
                      IsVisible="{Binding IsThumbnailsSidebarVisible}">
                    <Border Grid.Row="0"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <TextBlock Text="Thumbnails"
                                   FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                    <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding PageThumbnails}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="6" Padding="0" Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).GoToPageCommand}"
                                        CommandParameter="{Binding PageIndex}"
                                        Cursor="Hand"
                                        Classes.selected="{Binding IsSelected}">
                                    <Border Padding="6"
                                            Background="{DynamicResource CardBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Name="ThumbnailBorder">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding PageNumber, StringFormat='Page {0}'}"
                                                       HorizontalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <!-- EffectiveViewportChanged fires whenever this Image's
                                                 visible area changes. We use it to lazy-load the
                                                 thumbnail bitmap only for pages the user actually
                                                 scrolls to — combined with the on-disk cache
                                                 (ThumbnailCacheService) reopens are sub-millisecond
                                                 and first opens skip rendering pages they never look at. -->
                                            <Image Source="{Binding ThumbnailImage}"
                                                   Width="150" Height="200"
                                                   Stretch="Uniform"
                                                   EffectiveViewportChanged="OnThumbnailViewportChanged"
                                                   Tag="{Binding PageIndex}"/>
                                        </StackPanel>
                                    </Border>
                                    <Button.Styles>
                                        <Style Selector="Button.selected > Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource BrandPrimaryBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                            <Setter Property="Background" Value="{DynamicResource SelectedBrush}"/>
                                        </Style>
                                        <Style Selector="Button:pointerover > Border">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Grid>
              </Grid>
            </Border>

            <!-- PDF Viewer -->
            <Border Grid.Column="1"
                    Background="#E8E8E8">
                <Grid>
                    <!-- Empty State (shown when no document is loaded) -->
                    <Grid IsVisible="{Binding !IsDocumentLoaded}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                            <TextBlock Text="📄"
                                       FontSize="64"
                                       HorizontalAlignment="Center"
                                       Opacity="0.3"/>
                            <TextBlock Text="No document open"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Open a PDF file to get started"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <Button Content="📁 Open File"
                                    Command="{Binding OpenFileCommand}"
                                    HorizontalAlignment="Center"
                                    Padding="20,10"
                                    FontSize="14"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Document Viewer (shown when document is loaded) -->
                    <controls:PdfViewerControl x:Name="PdfViewerControl"
                                               IsVisible="{Binding IsDocumentLoaded}"
                                               Document="{Binding PdfCoreDocument}"
                                               CurrentPage="{Binding CurrentPage}"
                                               ZoomLevel="{Binding ZoomLevel}"
                                               InteractionMode="{Binding InteractionMode}"
                                               HiddenTextHighlights="{Binding HiddenTextHighlights}"
                                               FormFields="{Binding CurrentPageFormFields}"
                                               RedactionDrawn="OnRedactionDrawn"
                                               TextSelected="OnTextSelected"
                                               LinkClicked="OnLinkClicked"
                                               FormFieldEdited="OnFormFieldEdited"
                                               FormFieldRectDrawn="OnFormFieldRectDrawn"
                                               PageChanged="OnPageChanged" />
                </Grid>
            </Border>

            <!-- Clipboard History Sidebar -->
            <Border Grid.Column="2"
                    Width="250"
                    IsVisible="{Binding IsClipboardSidebarVisible}"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Header — title swaps with the right-sidebar mode. -->
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Search Results"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       IsVisible="{Binding ShowSearchResultsPanel}"/>
                            <TextBlock Grid.Column="0"
                                       Text="Pending Redactions"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       IsVisible="{Binding ShowPendingRedactionsPanel}"/>
                            <TextBlock Grid.Column="0"
                                       Text="Clipboard History"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       IsVisible="{Binding ShowClipboardHistoryPanel}"/>
                            <!-- Count badge for active mode. -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SearchMatches.Count, StringFormat='({0})'}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrandPrimaryBrush}"
                                       IsVisible="{Binding ShowSearchResultsPanel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding RedactionWorkflow.PendingCount, StringFormat='({0})'}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrandPrimaryBrush}"
                                       IsVisible="{Binding ShowPendingRedactionsPanel}"/>
                        </Grid>
                    </Border>

                    <!-- Search results list — visible whenever the find bar
                         is open. Each row jumps to its match on click. -->
                    <ScrollViewer Grid.Row="1" IsVisible="{Binding ShowSearchResultsPanel}">
                        <ItemsControl ItemsSource="{Binding SearchMatches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Margin="6,4"
                                            Padding="10"
                                            Background="{DynamicResource CardBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Cursor="Hand"
                                            Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).JumpToSearchMatchCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding MatchedText}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding PageIndex, StringFormat='p.{0}'}"
                                                           FontSize="11"
                                                           Margin="6,0,0,0"
                                                           Foreground="{DynamicResource BrandPrimaryBrush}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Context}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Pending Redactions List (visible in redaction mode, search bar closed). -->
                    <ScrollViewer Grid.Row="1" IsVisible="{Binding ShowPendingRedactionsPanel}">
                        <ItemsControl ItemsSource="{Binding RedactionWorkflow.PendingRedactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="8" Padding="10"
                                            Background="{DynamicResource CardBrush}"
                                            BorderBrush="#E53935"
                                            BorderThickness="2"
                                            CornerRadius="6">
                                        <StackPanel Spacing="6">
                                            <!-- Header: Page Number -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding PageNumber, StringFormat='Page {0}'}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource BrandPrimaryBrush}"/>
                                                <Button Grid.Column="1"
                                                        Content="×"
                                                        FontSize="16"
                                                        Padding="4,0"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RemovePendingRedactionCommand}"
                                                        CommandParameter="{Binding Id}"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Grid>

                                            <!-- Preview Text -->
                                            <TextBlock Text="{Binding PreviewText}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="60"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>

                                            <!-- Area info -->
                                            <TextBlock Text="{Binding DisplayText}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Redaction action buttons (visible in redaction mode, search bar closed). -->
                    <Border Grid.Row="2"
                            IsVisible="{Binding ShowPendingRedactionsPanel}"
                            Padding="12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*,8,*">
                            <!-- Clear All Button -->
                            <Button Grid.Column="0"
                                    Content="Clear All"
                                    Command="{Binding ClearAllRedactionsCommand}"
                                    HorizontalAlignment="Stretch"
                                    Padding="12,8"
                                    FontWeight="SemiBold"
                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"/>

                            <!-- Apply All Button (issue #19) -->
                            <Button Grid.Column="2"
                                    Content="Apply All"
                                    Command="{Binding ApplyAllRedactionsCommand}"
                                    IsEnabled="{Binding RedactionWorkflow.HasPendingRedactions}"
                                    HorizontalAlignment="Stretch"
                                    Classes="primary"
                                    Padding="12,8"
                                    FontWeight="SemiBold">
                                <Button.Styles>
                                    <Style Selector="Button.primary">
                                        <Setter Property="Background" Value="#E53935"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                    <Style Selector="Button.primary:pointerover">
                                        <Setter Property="Background" Value="#D32F2F"/>
                                    </Style>
                                    <Style Selector="Button.primary:disabled">
                                        <Setter Property="Background" Value="#666"/>
                                        <Setter Property="Foreground" Value="#999"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Clipboard History List (visible when neither redaction nor search active). -->
                    <ScrollViewer Grid.Row="1" IsVisible="{Binding ShowClipboardHistoryPanel}">
                        <ItemsControl ItemsSource="{Binding ClipboardHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:ClipboardEntry">
                                    <Border Margin="8" Padding="10"
                                            Background="{DynamicResource CardBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Classes.redacted="{Binding IsRedacted}">
                                        <Border.Styles>
                                            <Style Selector="Border.redacted">
                                                <Setter Property="BorderBrush" Value="#E53935"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </Style>
                                        </Border.Styles>
                                        <StackPanel Spacing="6">
                                            <!-- Header: Type, Time and Page -->
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0"
                                                        Background="#E53935"
                                                        CornerRadius="3"
                                                        Padding="6,2"
                                                        Margin="0,0,8,0"
                                                        IsVisible="{Binding IsRedacted}">
                                                    <TextBlock Text="REDACTED"
                                                               FontSize="9"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding TimeDisplay}"
                                                           FontSize="11"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource BrandPrimaryBrush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding PageNumber, StringFormat='Page {0}'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Grid>

                                            <!-- Preview Text -->
                                            <TextBlock Text="{Binding PreviewText}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="60"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>

                                            <!-- Character Count -->
                                            <TextBlock Text="{Binding CharacterCount, StringFormat='{}{0} characters'}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="6"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Mode Indicator -->
                <Border Grid.Column="0"
                        CornerRadius="4"
                        Padding="8,4"
                        Margin="0,0,12,0"
                        Classes.redactionActive="{Binding IsRedactionMode}">
                    <Border.Styles>
                        <!-- Normal mode style -->
                        <Style Selector="Border">
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                        </Style>
                        <!-- Redaction mode active style -->
                        <Style Selector="Border.redactionActive">
                            <Setter Property="Background" Value="#E53935"/>
                        </Style>
                    </Border.Styles>
                    <TextBlock Text="{Binding CurrentModeText}"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Medium"
                               Classes.redactionActive="{Binding IsRedactionMode}">
                        <TextBlock.Styles>
                            <!-- Normal mode text color -->
                            <Style Selector="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Style>
                            <!-- Redaction mode text color (white for contrast) -->
                            <Style Selector="TextBlock.redactionActive">
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </TextBlock.Styles>
                    </TextBlock>
                </Border>

                <!-- Status Text / Operation Status -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
                    <!-- Operation Status (shown when an operation is in progress) -->
                    <TextBlock Text="{Binding OperationStatus}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               IsVisible="{Binding OperationStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <!-- Regular Status Text (shown when no operation) -->
                    <TextBlock Text="{Binding StatusBarText}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               IsVisible="{Binding OperationStatus, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                </StackPanel>

                <!-- Page Navigation. No tooltips on the arrow buttons —
                     the "Page N" label between them already explains
                     them, and the flickering tooltip popup on hover (the
                     adjacent OperationStatus / StatusBarText cell flips
                     visibility while thumbnails load, re-measuring the
                     status-bar StackPanel and yanking the tooltip's
                     anchor out from under it on every tick) made the
                     buttons hard to click. AutomationProperties stay
                     for screen readers. -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Content="◀" Command="{Binding PreviousPageCommand}"
                            Classes="modern-button compact" Padding="8,4"
                            AutomationProperties.Name="Previous Page"
                            AutomationProperties.HelpText="Navigate to the previous page"/>
                    <TextBlock Text="{Binding DisplayPageNumber, StringFormat='Page {0}'}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               MinWidth="80"
                               TextAlignment="Center"
                               AutomationProperties.Name="Current Page Number"/>
                    <Button Content="▶" Command="{Binding NextPageCommand}"
                            Classes="modern-button compact" Padding="8,4"
                            AutomationProperties.Name="Next Page"
                            AutomationProperties.HelpText="Navigate to the next page"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
